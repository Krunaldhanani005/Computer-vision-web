# Copy this file to .env and fill in your actual values.
# .env is git-ignored — never commit it.

ROBOFLOW_API_KEY=your_roboflow_api_key_here
ROBOFLOW_MODEL_ENDPOINT=facial-emotion-recognition/2

# CCTV camera credentials — used for both FR and Restricted Area streams
# URL without credentials (they are injected by the backend)
CCTV_URL=rtsp://192.168.x.x:554/1/1?transmode=unicast&profile=vam
CCTV_USERNAME=your_username
CCTV_PASSWORD=your_password
